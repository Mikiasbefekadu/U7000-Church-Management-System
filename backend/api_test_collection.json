                  "pm.test('Role is ZONE_LEADER', () => pm.expect(json.role).to.eql('ZONE_LEADER'));",
                  "pm.test('Zone assigned', () => pm.expect(json.assignedZoneId).to.eql('Z001'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"zone1leader\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "POST Login (KCU Leader — KCU001 Scoped)",
          "event": [
            {
              "listen": "test",
