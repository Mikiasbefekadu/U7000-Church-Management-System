{
  "info": {
    "name": "Leadership Gold CMS — API Test Suite",
    "description": "Pre-configured Postman v2.1 collection for the Church Management System backend.\nBase URL: http://localhost:8080\n\nUSAGE:\n1. Run 'POST Login (Admin)' first — the collection auto-saves the token.\n2. All subsequent requests use {{token}} and {{baseUrl}} variables automatically.\n3. Seed data from import.sql must be loaded before running analytics tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "cms-leadership-gold-v1"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "POST Login (Admin — Global Access)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
                  "pm.test('Role is ADMIN', () => pm.expect(json.role).to.eql('ADMIN'));",
                  "console.log('Token saved:', json.token.substring(0, 40) + '...');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        },
        {
          "name": "POST Login (Zone Leader — Zone 1 Scoped)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
